{
  "name": "codemode-x",
  "version": "0.4.1",
  "description": "Compress any API, database, or docs into 2 MCP tools (cmx_search + cmx_execute)",
  "type": "module",
  "main": "dist/src/server.js",
  "bin": {
    "codemode-x": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "plugin",
    ".claude-plugin",
    ".mcp.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/codelitt/codemode-x"
  },
  "homepage": "https://github.com/codelitt/codemode-x#readme",
  "bugs": "https://github.com/codelitt/codemode-x/issues",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/plugin/start.mjs",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest",
    "test:live": "node --import tsx tests/live-e2e.ts",
    "cmx": "node dist/src/cli.js"
  },
  "keywords": ["claude-code", "mcp", "plugin", "sdk", "api"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0",
    "acorn": "^8.14.1",
    "acorn-walk": "^8.3.4",
    "better-sqlite3": "^11.8.1",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/acorn": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.12.0",
    "vitest": "^3.0.5"
  }
}
