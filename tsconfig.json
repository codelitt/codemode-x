{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "paths": {
      "#src/*": ["./src/*"],
      "#adapters/*": ["./adapters/*"]
    }
  },
  "include": ["src/**/*", "adapters/**/*", "plugin/**/*", "examples/**/*", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
